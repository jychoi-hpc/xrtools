## uniform split
def nsplit(a, n):
    k, m = divmod(len(a), n)
    return (a[i * k + min(i, m) : (i + 1) * k + min(i + 1, m)] for i in range(n))


def natural_key(text):
    # Split into list of strings and integers
    return [int(c) if c.isdigit() else c.lower() for c in re.split(r"(\d+)", text)]


def build_block_slices(shape, block_sizes):
    """Yield n-dimensional slices for block-wise data writes."""
    starts_per_dim = [range(0, size, block) for size, block in zip(shape, block_sizes)]
    for starts in itertools.product(*starts_per_dim):
        yield tuple(
            slice(start, min(start + block, size))
            for start, size, block in zip(starts, shape, block_sizes)
        )


