    if args.parallel:
        from mpi4py import MPI
        from netCDF4 import Dataset

        comm = MPI.COMM_WORLD
        comm_rank = comm.Get_rank()
        comm_size = comm.Get_size()

        outfile = args.outfile

        if comm_rank == 0:
            print(dx)
            print("output_path:", outfile)
            print("mode:", args.mode)

        if not args.dryrun:
            ds = Dataset(
                outfile,
                args.mode,
                parallel=True,
                comm=comm,
                info=MPI.Info(),
                format="NETCDF4",
            )

            for dim in dx.dims:
                if dim not in ds.dimensions:
                    print("Create dim:", dim)
                    ds.createDimension(dim, dx.dims[dim])

            for i, varname in enumerate(dx.data_vars):
                var = dx[varname]
                dtype = var.dtype

                block_sizes = tuple(
                    max(1, int(chunk.get(dim, var.sizes[dim]))) for dim in var.dims
                )
                if comm_rank == 0:
                    print(
                        f"Variable '{varname}' shape: {var.shape}, block sizes: {block_sizes} ({math.prod(block_sizes) * var.dtype.itemsize / 1024**2 :.2f} MB)"
                    )

                create_kwargs = {}
                if var.ndim > 0:
                    create_kwargs["chunksizes"] = block_sizes

                netcdf_var = ds.createVariable(
                    varname,
                    dtype,
                    dimensions=var.dims,
                    **create_kwargs,
                )

                # For parallel HDF5, collective mode is often safer for big chunked writes
                netcdf_var.set_collective(True)

                # Write data in parallel
                data = var.data

                if var.ndim == 0:
                    if comm_rank == 0:
                        netcdf_var[...] = data.compute()
                    continue

                total_blocks = math.prod(
                    math.ceil(size / block)
                    for size, block in zip(var.shape, block_sizes)
                )
                blocks = list(build_block_slices(var.shape, block_sizes))
                assert (
                    len(blocks) % comm_size == 0
                ), f"Total number of blocks must be divisible by total number of processes: {total_blocks} blocks, {comm_size} processes"

                local_blocks = 0
                for block_idx, slc in enumerate(blocks):
                    if block_idx % comm_size != comm_rank:
                        continue
                    local_blocks += 1

                pbar = tqdm(
                    total=local_blocks,
                    disable=(comm_rank != 0),
                    desc=f"{varname}",
                )

                for block_idx, slc in enumerate(blocks):
                    if block_idx % comm_size != comm_rank:
                        continue
                    # print(f"Rank {comm_rank} writing block {block_idx}/{total_blocks} for variable '{varname}': slices {slc}")

                    # import gc; gc.collect()
                    x = data[slc].compute()
                    netcdf_var[slc] = x

                    if comm_rank == 0:
                        pbar.update(1)

                if comm_rank == 0:
                    pbar.close()

            ds.close()

        print("Done.")
        sys.exit(0)

